# Groot Ops local environment template
# Copy this file to .env for local runs. Never commit .env or real credentials.

# Optional: Maton Google Sheets proxy API key for configs that use:
# repository.credentials_env: MATON_API_KEY
MATON_API_KEY=replace_with_maton_api_key

# Optional: native Google service-account JSON or path for configs that use:
# repository.credentials_env: GROOT_GOOGLE_SERVICE_ACCOUNT_JSON
# Value can be either raw service-account JSON or a file path.
GROOT_GOOGLE_SERVICE_ACCOUNT_JSON=/secure/path/groot-pilot-service-account.json

# Optional public base URL used in owner email dashboard buttons.
# Leave blank locally to use relative /clients/<id>/dashboard links.
GROOT_OPS_PUBLIC_BASE_URL=https://your-groot-ops-demo.example.com

# Recommended for Vercel/client pilots: protects /setup, /dashboard, and /clients/*.
# Share links as /setup?token=<token> or /clients/<client_id>/dashboard?token=<token>.
GROOT_OPS_DASHBOARD_TOKEN=replace_with_long_random_dashboard_token

# Stable PoC database. Use the Neon pooled or direct Postgres URL.
# Never commit the real value.
DATABASE_URL=postgresql://user:***@host/neondb?sslmode=require

# Optional Neon unpooled/direct URL. Useful for admin scripts or providers that expose both pooled and direct URLs.
DATABASE_URL_UNPOOLED=postgresql://user:***@host/neondb?sslmode=require

# Optional DB readiness connection timeout in seconds. Defaults to 5 in code.
GROOT_OPS_DB_CONNECT_TIMEOUT=5

# Optional Neon project API key for operator/admin scripts. Not needed by normal app runtime.
NEON_API_KEY=replace_with_neon_api_key

# Optional alternative used by repository.service_account_file: ${GOOGLE_APPLICATION_CREDENTIALS}
GOOGLE_APPLICATION_CREDENTIALS=/secure/path/groot-pilot-service-account.json
